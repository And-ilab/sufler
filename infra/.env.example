DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Development only. Use AUTH_MODE=ldap in production after P7-03 sign-off.
AUTH_MODE=mock_ldap
AUTH_MOCK_LDAP_DEFAULT_PASSWORD=replace-with-dev-only-password

# SUZ Model B webhook HMAC. Empty is allowed only for local mock development.
SUZ_WEBHOOK_HMAC_SECRET=replace-with-a-shared-suz-webhook-secret

# VI.3 structured audit. Add ",http" after configuring a KUMA collector URL.
AUDIT_ENABLED=true
AUDIT_SINKS=file
AUDIT_HTTP_COLLECTOR_URL=
AUDIT_HTTP_TIMEOUT_SECONDS=5
AUDIT_DEVICE_VENDOR=Belarusbank
AUDIT_DEVICE_PRODUCT=AI_Hub

POSTGRES_DB=sufler
POSTGRES_USER=sufler
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT_HOST=5432

REDIS_PORT_HOST=6379

MINIO_ROOT_USER=sufler
MINIO_ROOT_PASSWORD=replace-with-a-strong-minio-password
MINIO_API_PORT_HOST=9000
MINIO_CONSOLE_PORT_HOST=9001

BACKEND_PORT_HOST=8000
